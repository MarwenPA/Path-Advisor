# ai-service environment variables
# Copy to .env for local development (never commit .env)

# Shared secret with Django for JWT service-to-service auth (HS256)
# Must match AI_SERVICE_JWT_SECRET in root .env
AI_SERVICE_JWT_SECRET=dev-jwt-shared-secret-change-me

AI_SERVICE_JWT_TTL_SECONDS=300
AI_SERVICE_JWT_ALGORITHM=HS256
AI_SERVICE_APP_VERSION=0.1.0
AI_SERVICE_MODEL_VERSION=0.1.0-statistical
