FROM node:22-alpine

WORKDIR /app

# Copy manifest + .npmrc first for layer caching (npmrc enables legacy-peer-deps for next-intl).
COPY package.json package-lock.json* .npmrc* ./
RUN npm install --no-audit --no-fund --legacy-peer-deps

# App source is bind-mounted in dev; copy as fallback for one-shot runs.
COPY . .

EXPOSE 3000

ENV NEXT_TELEMETRY_DISABLED=1

CMD ["npm", "run", "dev"]
