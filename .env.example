# ============================================================================
# Path-Advisor — LOCAL DEVELOPMENT environment variables.
#
# ⚠️  THIS FILE IS FOR LOCAL DEV ONLY. ⚠️
# Never copy these values to a staging or production environment:
#   - DJANGO_DEBUG=true exposes stack traces and the Django debug toolbar.
#   - All secrets are well-known and committed to git.
# In staging/prod, use Doppler / Scaleway Secrets / etc. (see ADR-0001).
#
# Usage: `cp .env.example .env` then start the stack with `docker compose up -d`.
# `.env` is gitignored. Doppler integration deferred to a later sprint (Story 1.1 §4.10).
# ============================================================================

# ----- Django (apps/api) -----
DJANGO_SETTINGS_MODULE=path_advisor.settings.local
DJANGO_SECRET_KEY=dev-only-not-for-production-please-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api

# ----- PostgreSQL (shared by Django + ai-service) -----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=path_advisor
POSTGRES_USER=path_advisor
POSTGRES_PASSWORD=path_advisor_local_dev

# ----- Redis -----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ----- MinIO (S3-compatible local) -----
MINIO_ROOT_USER=minio_local
MINIO_ROOT_PASSWORD=minio_local_password
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minio_local
AWS_SECRET_ACCESS_KEY=minio_local_password
AWS_S3_REGION_NAME=us-east-1

# ----- Email (Mailpit in dev) -----
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=false
DEFAULT_FROM_EMAIL=no-reply@path-advisor.local

# ----- ai-service (FastAPI) -----
AI_SERVICE_URL=http://ai-service:8001
AI_SERVICE_JWT_SECRET=dev-jwt-shared-secret-change-me
AI_SERVICE_JWT_TTL_SECONDS=300

# ----- Next.js (apps/web) -----
# NEXT_PUBLIC_* values are baked into the client bundle (visible in browser).
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Server-side URL used by Next.js Server Components inside the container.
API_URL_SERVER=http://api:8000

# ----- Optional: Sentry (left empty in local) -----
SENTRY_DSN=
